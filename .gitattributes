# Normalize line endings: Git stores LF, checks out native on each OS.
* text=auto

# Force LF for cross-platform / container-consumed files.
*.sh        text eol=lf
Dockerfile  text eol=lf
*.cs        text eol=lf
*.csproj    text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Binary files — never normalize.
*.png binary
*.jpg binary
*.ico binary
*.pdf binary
